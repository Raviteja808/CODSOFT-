<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description"
        content="Personal Portfolio of a Software Developer showcasing projects, skills, and experience.">
    <title>Raviteja Naidu | Software Developer</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="assets/css/style.css">
</head>

<body>

    <!-- Header Section -->
    <header class="header">
        <div class="logo">
            <a href="#hero">&lt;JohnDoe /&gt;</a>
        </div>
        <nav class="nav">
            <ul class="nav-links">
                <li><a href="#about">About</a></li>
                <li><a href="#skills">Skills</a></li>
                <li><a href="#projects">Projects</a></li>
                <li><a href="#resume">Resume</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
        </nav>
    </header>

    <!-- Hero Section -->
    <section id="hero" class="hero hidden">
        <div class="hero-content">
            <h1>Hi, I'm <span class="highlight">Raviteja Naidu</span></h1>
            <h2>Full-Stack Software Developer</h2>
            <p>I build exceptional and accessible digital experiences for the web.</p>
            <div class="hero-buttons">
                <a href="#projects" class="btn primary">View My Work</a>
                <a href="#contact" class="btn secondary">Get In Touch</a>
            </div>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="about hidden">
        <h2 class="section-title">About Me</h2>
        <div class="about-container">
            <div class="about-image">
                <img src="assets/images/profile.png" alt="Raviteja Naidu - Software Developer">
                <div class="image-backdrop"></div>
            </div>
            <div class="about-text">
                <p>Hello! I'm John, a passionate software developer based in San Francisco. With a strong foundation in
                    both frontend and backend development, I enjoy creating things that live on the internet.</p>
                <p>My interest in web development started back in 2018 when I decided to try editing custom Tumblr
                    themes — turns out hacking together HTML & CSS taught me a lot about responsive design!</p>
                <p>Fast-forward to today, I've had the privilege of building high-performance, scalable web features for
                    various tech startups.</p>
            </div>
        </div>
    </section>

    <!-- Skills Section -->
    <section id="skills" class="skills hidden">
        <h2 class="section-title">My Skills</h2>
        <div class="skills-grid">
            <div class="skill-category">
                <h3>Frontend</h3>
                <div class="pills">
                    <span class="pill">React</span>
                    <span class="pill">Vue.js</span>
                    <span class="pill">TypeScript</span>
                    <span class="pill">HTML5/CSS3</span>
                    <span class="pill">Tailwind CSS</span>
                </div>
            </div>
            <div class="skill-category">
                <h3>Backend</h3>
                <div class="pills">
                    <span class="pill">Node.js</span>
                    <span class="pill">Python</span>
                    <span class="pill">Django</span>
                    <span class="pill">PostgreSQL</span>
                    <span class="pill">GraphQL</span>
                </div>
            </div>
            <div class="skill-category">
                <h3>Tools & Cloud</h3>
                <div class="pills">
                    <span class="pill">Git & GitHub</span>
                    <span class="pill">Docker</span>
                    <span class="pill">AWS</span>
                    <span class="pill">CI/CD</span>
                    <span class="pill">Figma</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Projects Section -->
    <section id="projects" class="projects hidden">
        <h2 class="section-title">Featured Projects</h2>
        <div class="projects-grid">
            <!-- Project 1 -->
            <div class="project-card">
                <div class="project-image">
                    <img src="assets/images/project1.png" alt="Analytics Dashboard">
                </div>
                <div class="project-info">
                    <h3>DataViz Dashboard</h3>
                    <p>A real-time analytics dashboard presenting complex data points with intuitive, interactive charts
                        using React and D3.js. Integrated with a Python/FastAPI backend.</p>
                    <div class="tech-stack">
                        <span>React</span>
                        <span>D3.js</span>
                        <span>Python</span>
                    </div>
                </div>
            </div>
            <!-- Project 2 -->
            <div class="project-card">
                <div class="project-image">
                    <img src="assets/images/project2.png" alt="E-commerce Application">
                </div>
                <div class="project-info">
                    <h3>Modern E-Commerce</h3>
                    <p>A high-performance e-commerce platform with seamless payment integration, a dynamic product
                        catalog, and user authentication using Next.js and Stripe.</p>
                    <div class="tech-stack">
                        <span>Next.js</span>
                        <span>Stripe</span>
                        <span>PostgreSQL</span>
                    </div>
                </div>
            </div>
            <!-- Project 3 -->
            <div class="project-card">
                <div class="project-image">
                    <img src="assets/images/project3.png" alt="AI Chat App">
                </div>
                <div class="project-info">
                    <h3>Nexus AI Chat</h3>
                    <p>An AI-powered communication tool featuring real-time messaging, smart auto-replies, and
                        context-aware suggestions leveraging WebSocket and OpenAI's API.</p>
                    <div class="tech-stack">
                        <span>Vue.js</span>
                        <span>WebSocket</span>
                        <span>Node.js</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Resume Section -->
    <section id="resume" class="resume hidden">
        <h2 class="section-title">Resume</h2>
        <div class="resume-content">
            <p>Interested in my past experiences and detailed technical background? Feel free to check out my resume.
            </p>
            <a href="#" class="btn primary download-btn">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path
                        d="M21 15V19C21 19.5304 20.7893 20.0391 20.4142 20.4142C20.0391 20.7893 19.5304 21 19 21H5C4.46957 21 3.96086 20.7893 3.58579 20.4142C3.21071 20.0391 3 19.5304 3 19V15M7 10L12 15M12 15L17 10M12 15V3"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                Download Resume PDF
            </a>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="contact hidden">
        <h2 class="section-title">Get In Touch</h2>
        <div class="contact-wrapper">
            <p class="contact-desc">My inbox is always open. Whether you have a question, a project proposal, or just
                want to say hi, I'll try my best to get back to you!</p>
            <div class="contact-info">
                <p><strong>Email:</strong> john.doe@example.com</p>
                <p><strong>Phone:</strong> +1 (555) 123-4567</p>
            </div>
            <form class="contact-form" onsubmit="event.preventDefault(); alert('Message sent successfully! (Demo)');">
                <div class="form-group">
                    <label for="name">Name</label>
                    <input type="text" id="name" required placeholder="Your Name">
                </div>
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" required placeholder="Your Email">
                </div>
                <div class="form-group">
                    <label for="message">Message</label>
                    <textarea id="message" required rows="5" placeholder="Your Message"></textarea>
                </div>
                <button type="submit" class="btn primary">Send Message</button>
            </form>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <p>&copy; <span id="year"></span> Raviteja Naidu. All rights reserved.</p>
        <p class="sub-footer">Built with HTML, CSS & Vanilla JS.</p>
    </footer>

    <script src="assets/js/script.js"></script>
</body>

</html>
